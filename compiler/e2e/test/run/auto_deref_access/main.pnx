## Case
## 10 20


extern "C":
    pub def printf(format: &uint8, ...) -> int32
    pub def scanf(format: &uint8, ...) -> int32


pub struct Pair[T, U]:
    pub first: T
    pub second: U


pub def main():
    let mut pair = Pair {
        first: 0,
        second: 0,
    }

    scanf(&"%d %d\0".[0], &mut pair.first, &mut pair.second)

    let pairRef = &pair

    printf(&"%d %d\n\0".[0], pairRef.first, pairRef.second)
