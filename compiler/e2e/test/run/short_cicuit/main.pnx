extern "C":
    pub def printf(fmt: &uint8, ...) -> int32
    pub def scanf(fmt: &uint8, ...) -> int32


pub def evalutesTrue() -> bool:
    printf(&"evalutesTrue called\n\0".[0])
    return true


pub def evaluatesFalse() -> bool:
    printf(&"evaluatesFalse called\n\0".[0])
    return false


pub def main():
    let firstResult = evalutesTrue() or evaluatesFalse()
    printf(&"firstResult: %d\n\0".[0], if firstResult: 1 else: 0)

    let secondResult = evaluatesFalse() and evalutesTrue()
    printf(&"secondResult: %d\n\0".[0], if secondResult: 1 else: 0)

    let thirdResult = evaluatesFalse() or evaluatesFalse()
    printf(&"thirdResult: %d\n\0".[0], if thirdResult: 1 else: 0)

    let fourthResult = evalutesTrue() and evalutesTrue()
    printf(&"fourthResult: %d\n\0".[0], if fourthResult: 1 else: 0)