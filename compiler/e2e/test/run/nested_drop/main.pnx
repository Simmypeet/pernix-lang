## Case
## 1 2
## 3 
## -4
## 0 


from core import Drop, Copy


extern "C":
    pub def printf(format: &uint8, ...) -> int32
    pub def scanf(format: &uint8, ...) -> int32


pub struct LoudDrop:
    priv value: int32


pub inst DropLoudDrop: Drop[LoudDrop]:
    def drop(self: &mut LoudDrop):
        unsafe scope:
            printf(&"Dropping %d\n\0".[0], self.value)


final impl Copy[LoudDrop] delete


pub struct Pair[T, U]:
    priv first: T
    priv second: U


pub inst DropPair[T, U]: Drop[Pair[T, U]]:
    def drop(self: &mut Pair[T, U]):
        unsafe scope:
            printf(&"Dropping Pair\n\0".[0])


final impl[T, U] Copy[Pair[T, U]] delete


pub enum LoudEnum:
    GtZero(LoudDrop)
    LtZero(LoudDrop)
    Zero


pub inst DropLoudEnum: Drop[LoudEnum]:
    def drop(self: &mut LoudEnum):
        match (self):
            as GtZero(..): 
                printf(&"Dropping GtZero\n\0".[0])

            as LtZero(..): 
                printf(&"Dropping LtZero\n\0".[0])

            as Zero:       
                printf(&"Dropping Zero\n\0".[0])


final impl Copy[LoudEnum] delete


pub def createLoudEnum() -> LoudEnum:
    let mut value = 0

    scanf(&"%d\0".[0], &mut value)

    if value > 0:
        return LoudEnum.GtZero(LoudDrop { value: value })

    else if value < 0:
        return LoudEnum.LtZero(LoudDrop { value: value })

    else:
        return LoudEnum.Zero


pub def main():
    let mut pair = Pair {
        first: LoudDrop { value: 0 },
        second: LoudDrop { value: 0 },
    }

    scanf(
        &"%d %d\0".[0], 
        &mut pair.first.value, 
        &mut pair.second.value
    )
    
    let first = createLoudEnum()
    let second = createLoudEnum()
    let third = createLoudEnum()
