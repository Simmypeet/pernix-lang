## Case
## 1 10
## Case
## 0 20


from core import Drop, Copy


extern "C":
    pub def printf(format: &uint8, ...) -> int32
    pub def scanf(format: &uint8, ...) -> int32


pub struct LoudDrop['a]:
    priv value: &'a mut int32


pub inst DropLoudDrop['x]: Drop[LoudDrop['x]]:
    def drop(self: &mut LoudDrop['x]):
        unsafe scope:
            printf(&"Dropping %d\n\0".[0], *self.value)


pub def drop[T](..: T):
    pass


pub def main():
    unsafe scope:
        let mut flag = 0
        let mut value = 0
        scanf(&"%d %d\0".[0], &mut flag, &mut value)

        let flag = flag != 0

        let loudDrop = LoudDrop { value: &mut value }

        if flag:
            drop(loudDrop)
            printf(&"loudDrop dropped early\n\0".[0])
        else:
            printf(&"loudDrop will be dropped in else\n\0".[0])
            # loudDrop will be dropped at the end of this scope
        
        printf(&"End of main\n\0".[0])

        