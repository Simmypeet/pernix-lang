from core import read, Copy

extern "C":
    pub def printf(format: &uint8, ...) -> int32


# Test scalar type
pub def testScalar():
    unsafe scope:
        let x = 42 as int32
        let ptr = (&x) as *int32
        let value = read[int32](ptr)
        printf(&"Scalar: %d\n\0".[0], value)


# Test aggregate type
pub struct Point:
    pub x: int32
    pub y: int32


final impl Copy[Point] delete


pub def testAggregate():
    unsafe scope:
        let p = Point { x: 10, y: 20 }
        let ptr = (&p) as *Point
        let p2 = read[Point](ptr)
        printf(&"Aggregate: (%d, %d)\n\0".[0], p2.x, p2.y)


# Test ZST
pub struct Empty:
    pass


final impl Copy[Empty] delete


pub def testZst():
    unsafe scope:
        let e = Empty {}
        let ptr = (&e) as *Empty
        let e2 = read[Empty](ptr)
        printf(&"ZST read complete\n\0".[0])


pub def main():
    testScalar()
    testAggregate()
    testZst()
