## Case
## 1 2 3 4 5 6 7

from core import Drop, Copy

extern "C":
    pub def printf(format: &uint8, ...) -> int32
    pub def scanf(format: &uint8, ...) -> int32


pub struct LoudDrop:
    priv value: int32


final impl Drop[LoudDrop]:
    def drop(self: &mut LoudDrop):
        unsafe scope:
            printf(&"Dropping %d\n\0".[0], self.value)
    

final impl Copy[LoudDrop] delete


pub struct Pair[T, U]:
    priv first: T
    priv second: U


pub enum Option[T]:
    Some(T)
    None


impl[T] Option[T]:
    pub def unwrap(self: this) -> T:
        match self:
            case Some(value): return value
            case None: panic
    

    pub def asRef(self: &this) -> Option[&T]:
        match self:
            case Some(value): return Option::Some(value)
            case None: return Option::None


    pub def asMutable(self: &mut this) -> Option[&mut T]:
        match self:
            case Some(value): return Option::Some(value)
            case None: return Option::None


pub def main():
    let mut inTuple = (LoudDrop { value: 0 }, LoudDrop { value: 0 })
    let mut inArray = [LoudDrop { value: 0 }, LoudDrop { value: 0 }]
    let mut inStruct = Pair {
        first: LoudDrop { value: 0 },
        second: LoudDrop { value: 0 },
    }

    let mut inSome = Option::Some(LoudDrop { value: 0 })
    let mut inNone = Option[LoudDrop]::None

    unsafe scope:
        scanf(&"%d %d %d %d %d %d %d\0".[0],
            &mut inTuple.0.value,
            &mut inTuple.1.value,
            &mut inArray.[0].value,
            &mut inArray.[1].value,
            &mut inStruct.first.value,
            &mut inStruct.second.value,
            &mut inSome.asMutable().unwrap().value, 
        )