## Case
## 1 2 3 4 5
## Case 
## 10 2 3 10 2


extern "C":
    pub def printf(fmt: &uint8, ...) -> int32
    pub def scanf(fmt: &uint8, ...) -> int32


pub def main():
    let mut a: int32 = 0
    let mut b: int32 = 0
    let mut c: int32 = 0
    let mut d: int32 = 0
    let mut e: int32 = 0

    scanf(&"%d %d %d %d %d\0".[0], &mut a, &mut b, &mut c, &mut d, &mut e)

    let result = a + b * c - d / e

    printf(&"%d\n\0".[0], result)

