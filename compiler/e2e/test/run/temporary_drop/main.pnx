from core import Drop, Copy


extern "C":
    pub def printf(format: &uint8, ...) -> int32
    pub def scanf(format: &uint8, ...) -> int32


pub struct LoudDrop:
    priv value: int32


pub inst DropLoudDrop: Drop[LoudDrop]:
    def drop(self: &mut LoudDrop):
        unsafe scope:
            printf(&"Dropping %d\n\0".[0], self.value)
    

final impl Copy[LoudDrop] delete


pub def createLoudDrop(value: int32) -> LoudDrop:
    let loudDrop = LoudDrop { value: value }
    return loudDrop


pub def main():
    createLoudDrop(1)
    
    printf(&"End of main\n\0".[0])