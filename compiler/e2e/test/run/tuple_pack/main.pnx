## Case
## 1 2 3 4 5 6


extern "C":
    pub def printf(format: &uint8, ...) -> int32
    pub def scanf(format: &uint8, ...) -> int32


pub trait Add[T]:
    pub def add(a: T, b: T) -> T


pub inst Int32Add: Add[int32]:
    def add(a: int32, b: int32) -> int32:
        return a + b


pub trait SumTuple[T: tuple]:
    pub type Output

    pub def sum(elements: T) -> this.Output


pub inst BaseCase[T, inst A: Add[T]]: SumTuple[(T,)]:
    type Output = T

    def sum(elements: (T,)) -> this.Output:
        return elements.0


pub inst RecursiveCase[T, Rest, inst A: Add[T], inst S: SumTuple[Rest]]: SumTuple[(T, ...Rest)]:
    where:
        Rest: tuple
        S.Output = T

    type Output = T

    def sum((first, ...rest): (T, ...Rest)) -> this.Output:
        return A.add(first, S.sum(rest))


pub def main():
    let mut nums = (
        0i32,
        0i32,
        0i32,
        0i32,
        0i32,
        0i32,
    )

    scanf(&"%d %d %d %d %d %d\0".[0], 
        &mut nums.0,
        &mut nums.1,
        &mut nums.2,
        &mut nums.3,
        &mut nums.4,
        &mut nums.5,
    )

    printf(&"%d\0".[0], RecursiveCase.sum(nums))