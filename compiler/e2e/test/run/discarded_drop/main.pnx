from core import Drop, Copy


extern "C":
    pub def printf(format: &uint8, ...) -> int32
    pub def scanf(format: &uint8, ...) -> int32


pub struct LoudDrop:
    priv value: int32


pub inst DropLoudDrop: Drop[LoudDrop]:
    def drop(self: &mut LoudDrop):
        printf(&"Dropping %d\n\0".[0], self.value)


final impl Copy[LoudDrop] delete


pub struct ZstLoudDrop:
    pass


pub inst DropZstLoudDrop: Drop[ZstLoudDrop]:
    def drop(self: &mut ZstLoudDrop):
        printf(&"Dropping ZST\n\0".[0])


final impl Copy[ZstLoudDrop] delete


pub def createLoudDrop(value: int32) -> LoudDrop:
    let loudDrop = LoudDrop { value: value }
    return loudDrop


pub def createZstLoudDrop() -> ZstLoudDrop:
    let zstLoudDrop = ZstLoudDrop {}
    return zstLoudDrop


pub def main():
    let mut value = 0i32
    scanf(&"%d\0".[0], &mut value)
    LoudDrop { value: value }

    scanf(&"%d\0".[0], &mut value)
    createLoudDrop(value)

    ZstLoudDrop {}
    createZstLoudDrop()