## Case
## 1 2 3 4 5


from core import Drop, Copy


extern "C":
    pub def printf(format: &uint8, ...) -> int32
    pub def scanf(format: &uint8, ...) -> int32


pub struct LoudDrop:
    priv value: int32


final impl Drop[LoudDrop]:
    def drop(self: &mut LoudDrop):
        unsafe scope:
            printf(&"Dropping %d\n\0".[0], self.value)


final impl Copy[LoudDrop] delete


pub def takeTuple[T, M: tuple, L](a: (T, ...M, L)):
    pass


pub def main():
    let mut nums = (
        LoudDrop { value: 0 },
        LoudDrop { value: 0 },
        LoudDrop { value: 0 },
        LoudDrop { value: 0 },
        LoudDrop { value: 0 },
    )

    scanf(&"%d %d %d %d %d\0".[0], 
        &mut nums.0.value, 
        &mut nums.1.value, 
        &mut nums.2.value, 
        &mut nums.3.value, 
        &mut nums.4.value
    )

    takeTuple[.., .., LoudDrop](nums)