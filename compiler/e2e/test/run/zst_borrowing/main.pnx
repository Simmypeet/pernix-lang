extern "C":
    pub def printf(format: &uint8, ...) -> int32


pub enum Option[T]:
    Some(T)
    None


pub def main():
    let value = ()
    let option = Option::Some(&value)

    match option:
        case Some(value):
            printf(&"is some\n\0".[0])

        case None:
            printf(&"is none\n\0".[0])