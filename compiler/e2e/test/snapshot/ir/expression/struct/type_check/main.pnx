pub struct Point:
    pub x: int32
    pub y: int32

pub struct WithGeneric[T, U]:
    pub first: T
    pub second: T
    pub third: T

    pub fourth: U
    pub fifth: U
    pub sixth: U


pub def main():
    # y is {{float}} but should be int32
    Point { x: 32, y: 64.0 }

    # third and fifth have wrong types
    WithGeneric {
        first: 32,
        second: 64i32,
        third: 128i64,

        fourth: 0,
        fifth: 0.54f64,
        sixth: true,
    }
    
    WithGeneric[bool, ..] {
        first: false,
        second: true,
        third: false,

        fourth: 0i64,
        fifth: 123,
        sixth: 123.3,
    }