pub def main(cond: bool):
    let a = scope 'result:
        if cond:
            express 'result 420

        # error scope 'result does not express on all flow paths


pub def anotherMain(cond: bool):
    let a = scope 'result:
        if cond:
            express 'result 420

        return 
        
        # fine, return exits the def, no need to express on this path 
        

pub def yetAnotherMain(cond: bool):
    let a = scope 'result:
        if cond:
            express 'result 420
        else:
            express 'result 64

        # fine, all flow paths express


pub def lastMain(cond: bool):
    let a = scope 'result:
        if cond:
            express 'result 420
        else:
            return
        
        # fine, return exits the def, no need to express on this path