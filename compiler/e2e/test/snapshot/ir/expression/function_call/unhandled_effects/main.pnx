pub effect Effect[T]:
    effectOp(t: T) -> T


pub def useEffectInt32() do Effect[int32]:
    pass


pub def useEffectFloat32() do Effect[float32]:
    pass


pub def useMultipleEffects() do Effect[int8] + Effect[int16]:    
    pass


pub def useUnhandledEffect() do Effect[float32]: 
    useEffectInt32()      # This should produce an unhandled effects error
    useEffectFloat32()  
    useMultipleEffects()  # This should produce an unhandled effects error