pub struct Test[T]:
    priv value: T


impl[L] Test[L]:
    pub def right[R](..: L, right: R) -> R:
        return right

    
    pub def left[R](left: L, ..: R) -> L:
        return left

    
    pub def both[R](left: L, right: R) -> (L, R):
        return (left, right)


pub def expect[T](..: T):
    pass


pub def expectSame[T](..: T, ..: T):
    pass
    

pub def expectSameCongruence[T](..: (T,), ..: (T,)):
    pass


pub def main():
    # normal case, no type error
    expect[int32](Test.right(true, 32))
    expect[bool](Test.left(true, 32))
    expect[(bool, int32)](Test.both(true, 32))
    
    # type mismatches
    expect[bool](Test.right(true, 32))
    expect[int32](Test.left(true, 32))
    expect[()](Test.both(true, 32)) 

    # same type
    expectSame(true, false)
    expectSame(32, 64f32)
    expectSameCongruence((32,), (64f32,))

    # not same type
    expectSame(true, 32)
    expectSame(32, true)
    expectSameCongruence((32,), (true,))