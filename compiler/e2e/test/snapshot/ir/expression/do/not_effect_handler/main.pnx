pub struct MyStruct:
    pass


pub enum MyEnum:
    pass


pub effect MyEffect:
    myEffectOp()


pub def main():
    do:
        pass

    with MyStruct: # totally not an effect handler
        pass
    
    with MyEnum: # totally not an effect handler
        pass
    
    with MyEffect: # this is an effect handler
        myEffectOp():
            pass