pub effect Test[T]:
    test(a: T, b: (T, T))


pub struct Vector2:
    pub x: int32
    pub y: int32


pub def main():
    do:
        pass

    with Test[Vector2]:
        test({x: aX, y: aY}, ({x: bX, y: bY}, {x: cX, y: cY})):
            pass


    with Test[int32]:
        # should error, int32 can't be destructured
        test({x: aX, y: aY}, ({x: bX, y: bY}, {x: cX, y: cY})):
            pass
