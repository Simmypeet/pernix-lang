pub def first():
    let .. = match true:
        true:  1
        true:  2  # unreachable
        false: 3 


pub enum Order:
    First
    Second
    Third


pub def second(order: Order):
    let .. = match order:
        case First:  1
        case Second: 2
        case First:  3  # unreachable
        case Third:  4


pub def third(order: Order):
    let .. = match order:
        case First:  1
        name:        3 
        case Third:  4 # unreachable

