pub def first():
    let .. = match true:
        true:  1
        true:  2  # unreachable
        false: 3 


pub enum Order:
    First
    Second
    Third


pub def second(order: Order):
    let .. = match order:
        as First:  1
        as Second: 2
        as First:  3  # unreachable
        as Third:  4


pub def third(order: Order):
    let .. = match order:
        as First:  1
        name:        3 
        as Third:  4 # unreachable
