pub def first():
    let .. = match true: # missing false arm
        true:  1


pub def second(a: bool, b: bool):
    let .. = match (a, b): # missing (false, false) arm
        (true, true):   1
        (true, false):  2
        (false, true):  3


pub def third(a: uint8):
    let .. = match a: # missing arms for 3..255
        0: 1
        1: 2
        2: 3


pub enum Direction:
    North
    East
    South
    West


pub def fourth(a: bool, direction: Direction):
    let .. = match (a, direction): # missing (false, West) arm
        (true, as North): 1
        (true, as East):  2
        (true, as South): 3
        (true, as West):  4

        (false, as North): 5
        (false, as East):  6
        (false, as South): 7


pub enum FakeBool:
    True
    False


pub def fifth(a: FakeBool, direction: Direction):
    let .. = match (a, direction): # missing (False, West) arm
        (as True,  as North): 1
        (as True,  as East):  2
        (as True,  as South): 3
        (as True,  as West):  4

        (as False, as North): 5
        (as False, as East):  6
        (as False, as South): 7
