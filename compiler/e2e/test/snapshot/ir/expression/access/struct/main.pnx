pub struct Inner:
    pub x: int32
    pub y: float32


pub struct Test:
    pub a: int32
    pub b: float32
    pub c: Inner


pub module inner:
    pub struct Private:
        priv privateField: int32


pub def test(test: Test, inner: inner::Private):
    # basic, existing fields
    test.a 
    test.b 
    test.c.x
    test.c.y

    # access, non-existing fields
    test.nonExistingField 
    test.c.nonExistingField

    # access, priv fields
    inner.privateField