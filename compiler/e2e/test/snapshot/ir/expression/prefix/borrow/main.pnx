pub def test():
    let a = 64
    let b = &mut a


pub def test2():
    let a = 64
    let b = &a
    let c = &mut *b


pub struct S:
    priv x: uint32


pub def test3(mut c: &S, d: &mut S):
    let a = &mut c.x
    let b = &c.x

    let e = &mut d.x
    let f = &d.x

pub struct U['x, 'y]:
    priv a: &'x S
    priv b: &'y mut S


pub def test4(mut u: U):
    let a = &mut u.a.x
    let b = &u.a.x

    let c = &mut u.b.x
    let d = &u.b.x