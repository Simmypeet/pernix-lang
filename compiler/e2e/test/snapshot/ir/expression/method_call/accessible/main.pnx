pub struct Test:
    pass


impl Test:
    priv def outerMethod(self: this):
        pass


pub module inner:
    import target.Test


    impl Test:
        priv def innerMethod(self: this):
            pass


    priv def innerMain():
        let t = Test{}
        t.innerMethod() # is fine
        t.outerMethod() # is fine


priv def outerMain():
    let t = Test{}
    t.innerMethod() # is not fine
    t.outerMethod() # is fine
