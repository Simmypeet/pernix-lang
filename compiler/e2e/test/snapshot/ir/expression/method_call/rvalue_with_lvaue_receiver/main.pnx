pub struct Pair:
    pub first: int32
    pub second: int32


pub def getPair() -> Pair:
    return Pair { first: 32, second: 64 }


impl Pair:
    pub def takeRValue(self: this):
        pass

    
    pub def takeLValue(self: &this):
        pass


    pub def takeMutableLValue(self: &mut this):
        pass


pub def main(): 
    getPair().takeRValue()
    getPair().takeLValue()
    getPair().takeMutableLValue()
