pub struct Pair[T, U]:
    pub first: T
    pub second: U


impl[T] Pair[T, T]:
    pub def swap(self: this) -> this:
        return this {
            first: self.second,
            second: self.first,
        }


pub def main():
    let a = Pair { first: true, second: 32 }
    let b = a.swap()
    
    let c = Pair { first: 32, second: true }
    let d = c.swap()

    let e = Pair { first: 32, second: 64 }
    let f = e.swap()

    let g = Pair { first: true, second: false }
    let h = g.swap()