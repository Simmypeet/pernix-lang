# fake vector
pub struct Vector[T]:
    priv _marker: phantom T


impl[T] Vector[T]:
    pub def new() -> this:
        return this { _marker: phantom }

    
    pub def push(self: &mut this, value: T):
        pass
    

pub def main():
    let mut vec = Vector.new()
    vec.push(true)
    vec.push(false)
    vec.push(53)  # error

    let mut newVec = Vector.new()

    # newVec type is not inferred