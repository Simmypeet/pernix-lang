pub struct Test:
    pub a: int32
    pub b: int32
    pub c: int32


pub def test(
    {a, b, c}: Test,
    {a: first, b: second, c: third}: Test,
):
    pass


pub def test2(
    {a, a}: Test,                # duplicate field binding
    {a: first, a: second}: Test, # duplicate field binding
):
    pass


pub def test3(
    {a: first, b: second, c: second}: Test, # duplicate name binding
):
    pass


pub def test4(
    {a, b, ..}: Test,
):
    pass


pub def test5(
    {..}: &Test,
):
    pass

pub def test6(
    {unknown}: Test, # unknown field 
):
    pass


pub module inner:
    pub struct Inaccessible:
        priv hidden: int32


pub def test7(
    {hidden}: inner::Inaccessible, # inaccessible field
):
    pass


pub def test8(
    {field}: int32, # not a struct
):
    pass