pub marker ImpossibleMarker[T]


pub struct MyStruct[T: ImpossibleMarker]:
    pub field: T


pub enum MyEnum[T: ImpossibleMarker]:
    Variant(T)


pub def main[T](a: T):
    let x = MyStruct { field: 5 }
    let y = MyEnum::Variant(10)
    let b = (true, ...a, false)


pub struct StructImmutableRef['a]:
    pub field: &'a int32


pub struct StructMutableRef['a]:
    pub field: &'a mut int32


pub def copyBehindRef(
    x: &StructImmutableRef,
    y: &StructMutableRef,
):
    let a = *x # fine
    let b = *y # not fine, mutable ref cannot be copied