pub trait Require[T]:
    pass


pub struct Box[T]:
    priv fake: phantom T


pub inst BoxInst[T, inst X: Require[T]]: Require[Box[T]]:
    pass


pub enum Option[T]:
    Some(T)
    None


pub inst OptionInst[T, inst X: Require[T]]: Require[Option[T]]:
    pass


pub struct LinkedList[T]:
    pub head: T
    pub tail: Option[Box[LinkedList[T]]]


pub inst LinkedListInst[
    T,
    inst H: Require[T],
    # error: this should cause a cyclic inst resolution error
    inst T: Require[Option[Box[LinkedList[T]]]],
]: Require[LinkedList[T]]:
    pass


pub inst Int32Inst: Require[int32]:
    pass


pub def require[T, inst I: Require[T]](value: T):
    pass


pub def useLinkedList():
    require(LinkedList { head: 1i32, tail: Option::None })