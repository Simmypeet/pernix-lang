public trait Require[T]:
    pass


public struct Box[T]:
    private fake: phantom T


public inst BoxInst[T, inst X: Require[T]]: Require[Box[T]]:
    pass


public enum Option[T]:
    Some(T)
    None


public inst OptionInst[T, inst X: Require[T]]: Require[Option[T]]:
    pass


public struct LinkedList[T]:
    public head: T
    public tail: Option[Box[LinkedList[T]]]


public inst LinkedListInst[
    T,
    inst H: Require[T],
    # error: this should cause a cyclic inst resolution error
    inst T: Require[Option[Box[LinkedList[T]]]],
]: Require[LinkedList[T]]:
    pass


public inst Int32Inst: Require[int32]:
    pass


public function require[T, inst I: Require[T]](value: T):
    pass


public function useLinkedList():
    require(LinkedList { head: 1i32, tail: Option::None })