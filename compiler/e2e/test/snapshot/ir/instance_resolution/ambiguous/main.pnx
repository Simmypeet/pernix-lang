public trait Order[T]:
    pass


public struct MaxHeap[T, instance O: Order[T]]:
    pass



public function requireOrder[T, instance O: Order[T]](value: T):
    pass


implements[T, instance O: Order[T]] MaxHeap[T, O]:
    public function withOrder[instance O2: Order[T]](value: T):
        # both `O` and `O2` are valid instances for `Order[T]`, so this should 
        # cause an ambiguous instance resolution error
        requireOrder(value)