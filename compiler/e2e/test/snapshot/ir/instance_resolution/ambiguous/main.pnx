pub trait Order[T]:
    pass


pub struct MaxHeap[T, inst O: Order[T]]:
    pass



pub def requireOrder[T, inst O: Order[T]](value: T):
    pass


impl[T, inst O: Order[T]] MaxHeap[T, O]:
    pub def withOrder[inst O2: Order[T]](value: T):
        # both `O` and `O2` are valid instances for `Order[T]`, so this should 
        # cause an ambiguous inst resolution error
        requireOrder(value)