pub trait Require[T]:
    pass


pub struct Test[T, U]:
    pub value: T
    pub other: U


pub inst TestInst[
    T, 
    U, 
    inst X: Require[T], 
    inst Y: Require[U]
]: Require[Test[T, U]]:
    pass


pub def require[T, inst I: Require[T]](value: T):
    pass


pub def useTest[T, U](a: T, b: U):
    require(Test { value: a, other: b })