public trait Require[T]:
    pass


public struct Test[T, U]:
    public value: T
    public other: U


public inst TestInst[
    T, 
    U, 
    inst X: Require[T], 
    inst Y: Require[U]
]: Require[Test[T, U]]:
    pass


public function require[T, inst I: Require[T]](value: T):
    pass


public function useTest[T, U](a: T, b: U):
    require(Test { value: a, other: b })