public trait Require[T]:
    pass


public inst Outer[T, inst X: Require[Test[T]]]: Require[Test[Test[T]]]:
    pass


public inst Inner[T, inst Y: Require[T]]: Require[Test[T]]:
    pass


public struct Test[T]:
    public value: T


public function require[T, inst I: Require[T]](test: T):
    pass


public function useTest[T](a: T):
    require(Test{value: Test{value: a}})
