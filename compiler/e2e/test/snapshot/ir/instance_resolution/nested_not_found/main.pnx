pub trait Require[T]:
    pass


pub inst Outer[T, inst X: Require[Test[T]]]: Require[Test[Test[T]]]:
    pass


pub inst Inner[T, inst Y: Require[T]]: Require[Test[T]]:
    pass


pub struct Test[T]:
    pub value: T


pub def require[T, inst I: Require[T]](test: T):
    pass


pub def useTest[T](a: T):
    require(Test{value: Test{value: a}})
