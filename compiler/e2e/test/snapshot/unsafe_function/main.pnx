pub struct MyType:
    pass


impl MyType:
    pub unsafe def dangerous(): 
        pass

    
    pub unsafe def dangerousMethod(self: &this):
        pass


pub unsafe def anotherDangerous():
    pass


pub trait MyTrait[T]:
    pub unsafe def traitDangerous()


pub def main[T, inst I: MyTrait[T]]():
    MyType.dangerous()
    anotherDangerous()
    MyType{}.dangerousMethod()
    I.traitDangerous()


pub def safeMain[T, inst I: MyTrait[T]](t: T):
    unsafe scope:
        MyType.dangerous()
        anotherDangerous()
        MyType{}.dangerousMethod()
        I.traitDangerous()
