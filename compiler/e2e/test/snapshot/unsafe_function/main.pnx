public struct MyType:
    pass


implements MyType:
    public unsafe function dangerous(): 
        pass

    
    public unsafe function dangerousMethod(self: &this):
        pass


public unsafe function anotherDangerous():
    pass


public trait MyTrait[T]:
    public unsafe function traitDangerous()


public function main[T, instance I: MyTrait[T]]():
    MyType::dangerous()
    anotherDangerous()
    MyType{}.dangerousMethod()
    I::traitDangerous()


public function safeMain[T, instance I: MyTrait[T]](t: T):
    unsafe scope:
        MyType::dangerous()
        anotherDangerous()
        MyType{}.dangerousMethod()
        I::traitDangerous()
