pub effect A[T]:
    a()


pub effect B[T]:
    b()


pub def notError['a]() -> int32 do A[&'static int32] + B[&'a int32]:
    return 0


pub def notErrorSame['a,]() -> int32 do B[&'a int32] + B[&'a int32]:
    return 0


pub def error['a]() -> int32 do B[&'a int32] + B[&'static int32]:
    return 0


pub def errorMay['a]() -> int32 do (
    B[&'a int32] + B[&'static int32]
    + A[&'a int32] + A[&'static int32]
):
    return 0