pub trait Displayable[T]:
    pub def display()


pub struct MyStruct:
    pass


pub enum MyEnum:
    Variant


# ADT implementation - members SHOULD have access modifiers
impl MyStruct:
    # This should generate an error: ADT members must have access modifiers
    def helper():
        pass
    

    # This is correct: ADT member with access modifier
    pub def publicMethod():
        pass

    
    priv def privateMethod():
        pass

    
    internal def internalMethod():
        pass


# ADT implementation with access modifiers on enum
impl MyEnum:
    # This should generate an error: ADT members must have access modifiers
    def enumHelper():
        pass
    

    # This is correct: ADT member with access modifier
    pub def enumMethod():
        pass
