pub type Reference['a, T] = &'a T:
    where:
        T: 'a


pub type MutableReference['a, T] = &'a mut T:
    where:
        T: 'a


impl['a, T] Reference['a, T]:
    where:
        T: 'a

    pass


impl['a, T] MutableReference['a, T]:
    where:
        T: 'a

    pass


