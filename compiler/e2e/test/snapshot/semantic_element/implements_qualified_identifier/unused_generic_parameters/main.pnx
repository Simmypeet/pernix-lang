pub enum Option[T]:
    pass


impl[T, U] Option[T]:  # U is unused
    pass


impl[T, U] Option[(T,)]: # U is unused
    pass


impl[T, U] Option[(Option[T], U)]: # all used
    pass


pub trait Iterator:
    pub type Item[T]


# error T and I is not inferrable
impl[T, inst I: Iterator] Option[I::Item[T]]:
    pass


impl['a, 'b, T: 'b] Option[&'a &'b T]: # all used
    where:
        'b: 'a

    pass


impl['a, 'b, T: 'a] Option[&'a T]: # 'b is unused
    pass