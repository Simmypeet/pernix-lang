pub trait Fizz:
    pub type Output['a, T]


pub struct MyStruct:
    pass


pub enum Test['a, 'b, T, U, inst I: Fizz]:
    where:
        I::Output['a, T] = int32
        
    UseT(T)
    UseU(U)
    UseTU((T, U))
    UseUnknown(Unknown)
    Plain
    UseAnother(MyStruct)
    UseTraitAssociatedType(I::Output['b, T])
