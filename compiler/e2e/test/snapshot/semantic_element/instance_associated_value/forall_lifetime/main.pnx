pub trait Test['a]:
    pass


pub inst MyTest['a]: Test['a]:
    pass


pub trait ExpectInstance:
    pub inst I: for['a] Test['a]


pub inst WfExpectedInstance: ExpectInstance:
    inst I: for['a] Test['a] = for['x] MyTest['x] 


pub inst NotWfExpectedInstance['x]: ExpectInstance:
    # error: because MyTest['x] impl for Test['x] for specific 'x
    inst I: for['a] Test['a] = MyTest['x]