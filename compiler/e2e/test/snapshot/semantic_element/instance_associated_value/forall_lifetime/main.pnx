public trait Test['a]:
    pass


public inst MyTest['a]: Test['a]:
    pass


public trait ExpectInstance:
    public inst I: for['a] Test['a]


public inst WfExpectedInstance: ExpectInstance:
    inst I: for['a] Test['a] = for['x] MyTest['x] 


public inst NotWfExpectedInstance['x]: ExpectInstance:
    # error: because MyTest['x] impl for Test['x] for specific 'x
    inst I: for['a] Test['a] = MyTest['x]