pub effect Fizz:
    fizz(a: &int32) -> &int32


pub effect Buzz:
    buzz(b: &int32, c: &int32)


pub effect FizzBuzz:
    fizzBuzz(d: &int32, e: &int32) -> &int32


pub struct Ref['a, T: 'a]:
    priv value: &'a T


pub effect FizzBuzzRef:
    fizzBuzzRef(f: Ref[int32]) -> Ref[int32]


pub effect FizzBuzzRefError:
    fizzBuzzRefError(f: Ref[int32], g: Ref[int32]) -> Ref[int32]