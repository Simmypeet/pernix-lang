pub trait FirstTrait[T]:
    pub type Member[U]


pub trait SecondTrait[T]:
    pub type Member[U]


pub trait ThirdTrait[T]:
    pub type Member[U]


pub marker FirstMarker[T]


pub marker SecondMarker[T]


pub type Test['a, 'b, 'c, T, U, V, inst I: FirstTrait[T]] = usize:
    where:
        I::Member[U] = usize
        T: FirstMarker
        T: tuple
        U: tuple
        V: const
        U: const
        T: 'a + 'b
        'a: 'b + 'c