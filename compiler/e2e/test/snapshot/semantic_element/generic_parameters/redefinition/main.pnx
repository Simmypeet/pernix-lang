pub type First['a, 'a, 'b] = &'a int32

pub type Second[T, T, U] = T

pub type Third[const N: usize, const N: usize, const M: float32] = int32

pub type Fourth[
    'a, 'a,
    T, T,
    const N: usize, const N: usize
] = &'a T:
    where:
        T: 'a


pub trait Test[T]:
    pass


pub type Fifth[T, inst I: Test[T], inst I: Test[int32]] = int32