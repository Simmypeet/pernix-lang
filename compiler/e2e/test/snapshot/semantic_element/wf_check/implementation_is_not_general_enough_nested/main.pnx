pub marker Fizz['a, T]


final impl['a, 'b, T: 'b] Fizz['a, &'b T]


final impl['a, 'b, T: 'b] Fizz['a, &'b mut T]:
    where:
        'a: 'b # this constraint makes lifetime 'a be specific to 'b


pub marker Buzz[T]


final impl[T] Buzz[T]:
    where:
        for['x] T: Fizz['x]


pub type WithRequirement[T] = T:
    where:
        T: Buzz


# this instantiation is valid
pub type First['a, T] = WithRequirement[&'a T]:
    where:
        T: 'a


# this instantiation is invalid (not general enough)
pub type Second['a, T] = WithRequirement[&'a mut T]:
    where:
        T: 'a