pub marker Marker[T]


final impl Marker[int32]


final impl Marker[bool]


pub struct MyStruct:
    pub a: int32
    pub b: bool


pub struct EmptyStruct:
    pass


pub enum MyEnum:
    A(int32)
    B(bool)


pub enum EmptyEnum:
    pass


pub type WithRequirement[T: Marker] = T


pub type InstMyStruct    = WithRequirement[MyStruct]
pub type InstEmptyStruct = WithRequirement[EmptyStruct]
pub type InstMyEnum      = WithRequirement[MyEnum]
pub type InstEmptyEnum   = WithRequirement[EmptyEnum]