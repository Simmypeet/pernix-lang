public struct Invariant['x, 'a]:
    where:
        'a: 'x

    private mutableRef: &'x mut &'a int32


public trait Identity:
    public type Output


public type ConstrainedInvariant['x, 'a, instance I: Identity] = int32:
    where:
        'a: 'x
        I::Output = Invariant['x, 'a]


# should error with 'b: 'a and 'a: 'b
public type UseInvariant['x, 'a, 'b, instance I: Identity] = ConstrainedInvariant['x, 'a, I]:
    where:
        'a: 'x
        'b: 'x
        I::Output = Invariant['x, 'b]


public struct ConstraintLifetime['a, T]:
    where:
        T: 'a


# should have no error since T: 'static
public type UseConstraintLifetimeWithStatic['a, T] = ConstraintLifetime['a, T]:
    where:
        T: 'static 


# should error with T: 'a
public type UseConstraintLifetime['a, T] = ConstraintLifetime['a, T]


public struct Bivariant['a]:
    pass


public type ConstraintBivariant['a, instance I: Identity] = int32:
    where:
        I::Output = Bivariant['a]


# should have no lifetime errors, since the lifetime 'a  of `Bivariant` is
# bivariant
public type UseConstraintBivariant['a, 'b, instance I: Identity] = ConstraintBivariant['a, I]:
    where:
        I::Output = Bivariant['b]