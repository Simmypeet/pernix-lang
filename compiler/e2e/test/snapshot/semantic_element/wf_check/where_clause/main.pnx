pub struct Invariant['x, 'a]:
    where:
        'a: 'x

    priv mutableRef: &'x mut &'a int32


pub trait Identity:
    pub type Output


pub type ConstrainedInvariant['x, 'a, inst I: Identity] = int32:
    where:
        'a: 'x
        I.Output = Invariant['x, 'a]


# should error with 'b: 'a and 'a: 'b
pub type UseInvariant['x, 'a, 'b, inst I: Identity] = ConstrainedInvariant['x, 'a, I]:
    where:
        'a: 'x
        'b: 'x
        I.Output = Invariant['x, 'b]


pub struct ConstraintLifetime['a, T]:
    where:
        T: 'a


# should have no error since T: 'static
pub type UseConstraintLifetimeWithStatic['a, T] = ConstraintLifetime['a, T]:
    where:
        T: 'static 


# should error with T: 'a
pub type UseConstraintLifetime['a, T] = ConstraintLifetime['a, T]


pub struct Bivariant['a]:
    pass


pub type ConstraintBivariant['a, inst I: Identity] = int32:
    where:
        I.Output = Bivariant['a]


# should have no lifetime errors, since the lifetime 'a  of `Bivariant` is
# bivariant
pub type UseConstraintBivariant['a, 'b, inst I: Identity] = ConstraintBivariant['a, I]:
    where:
        I.Output = Bivariant['b]