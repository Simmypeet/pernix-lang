pub trait Test['a]:
    pass


pub type RequireForall[inst I: for['x] Test['x]] = int32


# error, lifetime is not general enough
pub type UseError['a, inst I: Test['a]] = RequireForall[I]


# good, lifetime is general enough
pub type UseOk[inst I: for['x] Test['x]] = RequireForall[I]


pub type RequireSpecific['a, inst I: Test['a]] = int32


# good, I can accept any lifetime, including 'static
pub type UseOkSpecific[inst I: for['x] Test['x]] = RequireSpecific['static, I]