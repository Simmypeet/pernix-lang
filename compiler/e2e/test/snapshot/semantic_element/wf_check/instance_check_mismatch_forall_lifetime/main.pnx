public trait Test['a]:
    pass


public type RequireForall[inst I: for['x] Test['x]] = int32


# error, lifetime is not general enough
public type UseError['a, inst I: Test['a]] = RequireForall[I]


# good, lifetime is general enough
public type UseOk[inst I: for['x] Test['x]] = RequireForall[I]


public type RequireSpecific['a, inst I: Test['a]] = int32


# good, I can accept any lifetime, including 'static
public type UseOkSpecific[inst I: for['x] Test['x]] = RequireSpecific['static, I]