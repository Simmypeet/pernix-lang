pub marker ForAllFail[T, U]


final impl[T] ForAllFail[T, T]


pub def requireForallFail[T: 'static]():
    where:
        for['x, 'y] &'x T: ForAllFail[&'y T]
    

pub def useForallFail():
    requireForallFail[int32]()


pub marker ForAllPass[T, U]


final impl[T, U] ForAllPass[T, U]


pub def requireForallPass[T: 'static]():
    where:
        for['x] &'x T: ForAllPass[&'x T]
    

pub def useForallPass():
    requireForallPass[int32]()
    