# fake vector
pub struct Vector[T]:
    priv _marker: phantom T


impl[T] Vector[T]:
    pub def new() -> this:
        panic

    
    pub def push['a](self: &'a mut this, value: T):
        where:
            T: 'a
            

pub def main(cond: bool):
    let mut vector = Vector.new()

    while cond:
        let mut number = 0
        vector.push(&number)