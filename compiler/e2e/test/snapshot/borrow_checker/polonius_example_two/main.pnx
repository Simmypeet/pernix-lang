# fake vector
pub struct Vector[T]:
    priv _marker: phantom T


impl[T] Vector[T]:
    pub def new() -> this:
        panic


    pub def push['a](self: &'a mut this, value: T):
        where:
            T: 'a


pub def consume[T](x: T):
    pass


pub def main():
    let mut v = Vector.new()
    let p = &mut v
    let mut x = 1

    x = 2

    p.push(&x)

    x = 3

    consume(v)