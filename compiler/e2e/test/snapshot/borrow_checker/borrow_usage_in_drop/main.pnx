from core import Drop, Copy


pub struct DropWrapper[T]:
    priv value: T


impl[T] DropWrapper[T]:
    pub def new(value: T) -> this:
        return this { value: value }


priv inst DropWrapperDrop[T]: Drop[DropWrapper[T]]:
    def drop['b](self: &'b mut DropWrapper[T]):
        where:
            DropWrapper[T]: 'b 


final impl[T] Copy[DropWrapper[T]] delete


pub def main():
    let mut number = 32
    let wrapper = DropWrapper::new(&number)

    number += 23