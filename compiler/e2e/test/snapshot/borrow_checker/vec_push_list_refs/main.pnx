pub enum Option[T]:
	Some(T)
	None


impl[T] Option[T]:
	pub def isSome['a](self: &'a this ) -> bool:
        where:
            T: 'a
	
		match self:
			case Some(_): return true
			case None:    return false
			

	pub def asRef['a](self: &'a this) -> Option[&'a T]:
        where:
            T: 'a

		match self:
			case Some(value): return Option::Some(value)
			case None: return Option::None


    pub def asMutable['a](
        self: &'a mut this
    ) -> Option[&'a mut T]:
        where:
            T: 'a

        match self:
            case Some(value): return Option::Some(value)
            case None: return Option::None


    pub def unwrap(self: this) -> T:
        match self:
            case Some(value): return value
            case None: panic


# fake vector
pub struct Vector[T]:
    priv _marker: phantom T


impl[T] Vector[T]:
    pub def new() -> this:
        panic


    pub def push['a](self: &'a mut this, value: T):
        where:
            T: 'a


pub struct List[T]:
	pub value: T
    
    # NOTE: this will create infinite sized struct in the future (use Box)
	pub next: Option[List[T]] 


pub def createList[T]() -> List[T]:
	panic
    

pub def getRefs['a, T](
	mut list: &'a mut List[T]
) -> Vector[&'a mut T]:
    where:
        T: 'a

	let mut vector = Vector::new()

	loop:
		vector.push(&mut list.value)

		match (&mut list.next):
			case Some(next):
				list = next

			case None: return vector