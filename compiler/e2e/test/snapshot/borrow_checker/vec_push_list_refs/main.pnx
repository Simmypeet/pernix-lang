pub enum Option[T]:
	Some(T)
	None


pub struct Box[T]:
    priv fake: phantom T


impl[T] Box[T]:
    pub def asMutable['a](self: &'a mut this) -> &'a mut T:
        where:
            T: 'a

        panic


impl[T] Option[T]:
	pub def isSome['a](self: &'a this ) -> bool:
        where:
            T: 'a
	
		match self:
			as Some(_): return true
			as None:    return false
			

	pub def asRef['a](self: &'a this) -> Option[&'a T]:
        where:
            T: 'a

		match self:
			as Some(value): return Option.Some(value)
			as None: return Option.None


    pub def asMutable['a](
        self: &'a mut this
    ) -> Option[&'a mut T]:
        where:
            T: 'a

        match self:
            as Some(value): return Option.Some(value)
            as None: return Option.None


    pub def unwrap(self: this) -> T:
        match self:
            as Some(value): return value
            as None: panic


# fake vector
pub struct Vector[T]:
    priv _marker: phantom T


impl[T] Vector[T]:
    pub def new() -> this:
        panic


    pub def push['a](self: &'a mut this, value: T):
        where:
            T: 'a


pub struct List[T]:
	pub value: T

	pub next: Option[Box[List[T]]]


pub def createList[T]() -> List[T]:
	panic
    

pub def getRefs['a, T](
	mut list: &'a mut List[T]
) -> Vector[&'a mut T]:
    where:
        T: 'a

	let mut vector = Vector.new()

	loop:
		vector.push(&mut list.value)

		match (&mut list.next):
			as Some(next):
				list = next.asMutable()

			as None: return vector
