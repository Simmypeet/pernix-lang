# fake vector
pub struct Vector[T]:
    priv _marker: phantom T


impl[T] Vector[T]:
    pub def new() -> this:
        panic


    pub def push['a](self: &'a mut this, value: T):
        where:
            T: 'a


pub def consume[T](x: T):
    pass


pub def main(cond: bool):
    let mut x = 1
    let mut v = Vector.new()
    let p = &x

    if cond:
        v.push(p)
    else:
        x = 2

    x = 3

    consume(v)