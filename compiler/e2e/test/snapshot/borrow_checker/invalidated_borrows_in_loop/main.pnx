# fake vector
pub struct Vector[T]:
    priv _marker: phantom T


impl[T] Vector[T]:
    pub def new() -> this:
        panic

    pub def clear['a](self: &'a mut this):
        where:
            T: 'a

        panic

    pub def push['a](self: &'a mut this, value: T):
        where:
            T: 'a

        panic

pub def main(cond: bool):
    let mut vector = Vector.new()
    let mut number = 0

    while cond:
        vector.push(&mut number)