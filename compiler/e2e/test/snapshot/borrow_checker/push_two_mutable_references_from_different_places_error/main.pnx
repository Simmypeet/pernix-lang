# fake vector
pub struct Vector[T]:
    priv _marker: phantom T


impl[T] Vector[T]:
    pub def new() -> this:
        panic


    pub def push['a](self: &'a mut this, value: T):
        where:
            T: 'a

pub def main(cond: bool):
    let mut first = 32
    let mut second = 64
    let mut vector = Vector.new()

    let mut ref = &mut first
    vector.push(&mut *ref)

    if cond:
        ref = &mut second
    else:
        # no reassignment, will error
        pass

    
    vector.push(&mut *ref)