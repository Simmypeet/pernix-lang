# fake vector
pub struct Vector[T]:
    priv _marker: phantom T


impl[T] Vector[T]:
    pub def new() -> this:
        panic


    pub def push['a](self: &'a mut this, value: T):
        where:
            T: 'a


pub def test['a, 'b](
	vector: &'a mut Vector[&'b mut int32],
	number: &'b mut int32
) -> &'b mut int32:
    where:
        'b: 'a

	# mutable ref number has already been stored in vector
	vector.push(number)

	# the caller can use the extra mutable reference, which is invalid
	return number