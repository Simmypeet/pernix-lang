pub effect Test['a]:
    takeMut(x: &'a mut int32)


pub def useIndirectly['a](x: &'a mut int32) do Test['a]:
    Test::takeMut(x)


pub def test['a](x: &'a mut int32) do Test['a]:
    Test::takeMut(x)
    Test::takeMut(x) # This should error because `x` is borrowed as mutable already


pub def anotherMain['a](x: &'a mut int32) do Test['a]:
    useIndirectly(x)
    useIndirectly(x) # This should error because `x` is borrowed as mutable already