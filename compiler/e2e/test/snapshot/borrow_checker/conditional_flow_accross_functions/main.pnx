from core import Copy


pub enum Option[T]:
	Some(T)
	None


impl[T] Option[T]:
	pub def isSome['a](self: &'a this ) -> bool:
        where:
            T: 'a
	
		match self:
			case Some(_): return true
			case None:    return false
			

	pub def asRef['a](self: &'a this) -> Option[&'a T]:
        where:
            T: 'a

		match self:
			case Some(value): return Option.Some(value)
			case None: return Option.None


    pub def asMutable['a](
        self: &'a mut this
    ) -> Option[&'a mut T]:
        where:
            T: 'a

        match self:
            case Some(value): return Option.Some(value)
            case None: return Option.None


    pub def unwrap(self: this) -> T:
        match self:
            case Some(value): return value
            case None: panic


# fake vector
pub struct Vector[T]:
    priv _marker: phantom T


impl[T] Vector[T]:
    pub def new() -> this:
        panic


    pub def push['a](self: &'a mut this, value: T):
        where:
            T: 'a


pub struct HashMap[K, V]:
	priv test: phantom (K, V)


impl[K, V] HashMap[K, V]:
	pub def new() -> this:
		return this {
			test: phantom
		}


	pub def insert['a](
		self: &'a mut this, 
		key: K, 
		value: V
	) -> Option[V]:
        where:
            K: 'a
            V: 'a 

		panic


	pub def get['a, 'b](
		self: &'a this, 
		key: &'b K
	) -> Option[&'a V]:
        where:
            K: 'a + 'b
            V: 'a

		panic


	pub def getOrDefault['a](
		self: &'a mut this, 
		key: K,
		default: V
	) -> &'a V:
        where:
            K: 'a + Copy
            V: 'a

		match self.get(&key):
			case Some(value):
				return value

			case None:
				self.insert(key, default)
				return self.get(&key).unwrap()