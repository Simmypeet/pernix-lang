pub struct Vector[T]:
    priv _marker: phantom T

impl[T] Vector[T]:
    pub def new() -> this:
        panic

    pub def push['a](self: &'a mut this, value: T):
        where:
            T: 'a

pub def main():
    let mut number = 0
    let mut vector = Vector::new()

    let v = &mut vector
    let n = &mut number
    v.push(n)

    let v = &mut vector
    let n = &mut number
    v.push(n)