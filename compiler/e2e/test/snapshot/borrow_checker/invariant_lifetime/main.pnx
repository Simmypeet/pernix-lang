pub def consume[T](x: T):
    pass


pub def assign['a, T] (
    reference: &'a mut T,
    value: T
):
    where:
        T: 'a

    *reference = value


pub def test():
    let outer =  32
    let mut ref = &outer

    scope:
        let inner = 0
        assign(&mut ref, &inner)

    consume(*ref)
