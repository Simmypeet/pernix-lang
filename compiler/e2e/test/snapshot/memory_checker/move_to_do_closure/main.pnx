from core import Copy


pub struct NonCopyable:
    pass


final impl Copy[NonCopyable] delete


pub effect Test:
    doSomething()


pub def drop[T](..: T):
    pass


pub def main():
    let nonCopyable = NonCopyable{}
    
    do: # the `nonCopyable` is moved here
        drop(nonCopyable)
    
    with Test:
        doSomething():
            pass

    # error: use of moved value `nonCopyable`
    drop(nonCopyable)