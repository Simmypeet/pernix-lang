from core import Copy


pub struct NonCopyable:
    pass


final impl Copy[NonCopyable] delete


pub def drop[T](..: T):
    pass


pub effect Test:
    operation()


pub def main():
    do: 
        let nc = NonCopyable{}
        drop(nc)
        drop(nc) # this is not fine

    with Test:
        operation():
            let nc = NonCopyable{}
            drop(nc)
            drop(nc) # this is not fine