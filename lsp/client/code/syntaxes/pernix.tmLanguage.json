{
    "information_for_contributors": ["textmate language grammars for Pernix."],
    "name": "Pernix",
    "scopeName": "source.pernix",
    "fileTypes": ["pnx"],
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#attributes"
        },
        {
            "include": "#generics"
        },
        {
            "include": "#lifetime"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#characters"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#punctuation"
        },
        {
            "include": "#types"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#identifiers"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.pernix",
                    "match": "#.*$"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "meta.struct.pernix",
                    "begin": "\\b(struct)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
                    "end": "(?=[:{]|$)",
                    "beginCaptures": {
                        "1": {
                            "name": "storage.type.pernix"
                        },
                        "2": {
                            "name": "entity.name.type.struct.pernix"
                        }
                    },
                    "patterns": [
                        {
                            "name": "meta.generic.declaration.pernix",
                            "begin": "\\[",
                            "end": "\\]",
                            "patterns": [
                                {
                                    "include": "#lifetime"
                                },
                                {
                                    "include": "#types"
                                },
                                {
                                    "include": "#keywords"
                                },
                                {
                                    "include": "#operators"
                                },
                                {
                                    "include": "#punctuation"
                                },
                                {
                                    "include": "#identifiers"
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "meta.enum.pernix",
                    "begin": "\\b(enum)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
                    "end": "(?=[:{]|$)",
                    "beginCaptures": {
                        "1": {
                            "name": "storage.type.pernix"
                        },
                        "2": {
                            "name": "entity.name.type.enum.pernix"
                        }
                    },
                    "patterns": [
                        {
                            "name": "meta.generic.declaration.pernix",
                            "begin": "\\[",
                            "end": "\\]",
                            "patterns": [
                                {
                                    "include": "#lifetime"
                                },
                                {
                                    "include": "#types"
                                },
                                {
                                    "include": "#keywords"
                                },
                                {
                                    "include": "#operators"
                                },
                                {
                                    "include": "#punctuation"
                                },
                                {
                                    "include": "#identifiers"
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "meta.trait.pernix",
                    "begin": "\\b(trait)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
                    "end": "(?=[:{]|$)",
                    "beginCaptures": {
                        "1": {
                            "name": "storage.type.pernix"
                        },
                        "2": {
                            "name": "entity.name.type.trait.pernix"
                        }
                    },
                    "patterns": [
                        {
                            "name": "meta.generic.declaration.pernix",
                            "begin": "\\[",
                            "end": "\\]",
                            "patterns": [
                                {
                                    "include": "#lifetime"
                                },
                                {
                                    "include": "#types"
                                },
                                {
                                    "include": "#keywords"
                                },
                                {
                                    "include": "#operators"
                                },
                                {
                                    "include": "#punctuation"
                                },
                                {
                                    "include": "#identifiers"
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "meta.type.pernix",
                    "begin": "\\b(type)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
                    "end": "(?=[=:{]|$)",
                    "beginCaptures": {
                        "1": {
                            "name": "storage.type.pernix"
                        },
                        "2": {
                            "name": "entity.name.type.alias.pernix"
                        }
                    },
                    "patterns": [
                        {
                            "name": "meta.generic.declaration.pernix",
                            "begin": "\\[",
                            "end": "\\]",
                            "patterns": [
                                {
                                    "include": "#lifetime"
                                },
                                {
                                    "include": "#types"
                                },
                                {
                                    "include": "#keywords"
                                },
                                {
                                    "include": "#operators"
                                },
                                {
                                    "include": "#punctuation"
                                },
                                {
                                    "include": "#identifiers"
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "meta.effect.pernix",
                    "begin": "\\b(effect)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
                    "end": "(?=[:{]|$)",
                    "beginCaptures": {
                        "1": {
                            "name": "storage.type.pernix"
                        },
                        "2": {
                            "name": "entity.name.type.effect.pernix"
                        }
                    },
                    "patterns": [
                        {
                            "name": "meta.generic.declaration.pernix",
                            "begin": "\\[",
                            "end": "\\]",
                            "patterns": [
                                {
                                    "include": "#lifetime"
                                },
                                {
                                    "include": "#types"
                                },
                                {
                                    "include": "#keywords"
                                },
                                {
                                    "include": "#operators"
                                },
                                {
                                    "include": "#punctuation"
                                },
                                {
                                    "include": "#identifiers"
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "meta.marker.pernix",
                    "begin": "\\b(marker)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
                    "end": "(?=[:{]|$)",
                    "beginCaptures": {
                        "1": {
                            "name": "storage.type.pernix"
                        },
                        "2": {
                            "name": "entity.name.type.marker.pernix"
                        }
                    },
                    "patterns": [
                        {
                            "name": "meta.generic.declaration.pernix",
                            "begin": "\\[",
                            "end": "\\]",
                            "patterns": [
                                {
                                    "include": "#lifetime"
                                },
                                {
                                    "include": "#types"
                                },
                                {
                                    "include": "#keywords"
                                },
                                {
                                    "include": "#operators"
                                },
                                {
                                    "include": "#punctuation"
                                },
                                {
                                    "include": "#identifiers"
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "meta.instance.pernix",
                    "begin": "\\b(inst)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
                    "end": "(?=[:{]|$)",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.other.pernix"
                        },
                        "2": {
                            "name": "entity.name.type.instance.pernix"
                        }
                    },
                    "patterns": [
                        {
                            "name": "meta.generic.declaration.pernix",
                            "begin": "\\[",
                            "end": "\\]",
                            "patterns": [
                                {
                                    "include": "#lifetime"
                                },
                                {
                                    "include": "#types"
                                },
                                {
                                    "include": "#keywords"
                                },
                                {
                                    "include": "#operators"
                                },
                                {
                                    "include": "#punctuation"
                                },
                                {
                                    "include": "#identifiers"
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "keyword.control.pernix",
                    "match": "\\b(if|else|match|case|while|for|loop|break|continue|return|try|with|do)\\b"
                },
                {
                    "name": "keyword.control.import.pernix",
                    "match": "\\b(import|from)\\b"
                },
                {
                    "name": "keyword.other.pernix",
                    "match": "\\b(let|const|mut|static|as|where|given|pass)\\b"
                },
                {
                    "name": "storage.type.pernix",
                    "match": "\\b(tuple)\\b"
                },
                {
                    "name": "storage.modifier.pernix",
                    "match": "\\b(pub|priv|internal|extern|unsafe|final|phantom)\\b"
                },
                {
                    "name": "keyword.other.pernix",
                    "match": "\\b(impl|express|scope|resume)\\b"
                },
                {
                    "name": "keyword.other.pernix",
                    "match": "\\b(module|target|super|this|delete)\\b"
                },
                {
                    "name": "constant.language.boolean.pernix",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language.pernix",
                    "match": "\\b(null)\\b"
                },
                {
                    "name": "keyword.control.panic.pernix",
                    "match": "\\b(panic)\\b"
                },
                {
                    "name": "keyword.operator.logical.pernix",
                    "match": "\\b(and|or|not)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.pernix",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.pernix",
                            "match": "\\\\(x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]{1,6}\\}|[0nrt'\"\\\\])"
                        },
                        {
                            "name": "invalid.illegal.unknown-escape.pernix",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "characters": {
            "patterns": [
                {
                    "name": "string.quoted.single.pernix",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.pernix",
                            "match": "\\\\(x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]{1,6}\\}|[0nrt'\"\\\\])"
                        },
                        {
                            "name": "invalid.illegal.unknown-escape.pernix",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.pernix",
                    "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?(float32|float64|f32|f64)?\\b"
                },
                {
                    "name": "constant.numeric.hex.pernix",
                    "match": "\\b0x[0-9a-fA-F][0-9a-fA-F_]*(i8|i16|i32|i64|u8|u16|u32|u64|isize|usize|int8|int16|int32|int64|uint8|uint16|uint32|uint64)?\\b"
                },
                {
                    "name": "constant.numeric.binary.pernix",
                    "match": "\\b0b[01][01_]*(i8|i16|i32|i64|u8|u16|u32|u64|isize|usize|int8|int16|int32|int64|uint8|uint16|uint32|uint64)?\\b"
                },
                {
                    "name": "constant.numeric.octal.pernix",
                    "match": "\\b0o[0-7][0-7_]*(i8|i16|i32|i64|u8|u16|u32|u64|isize|usize|int8|int16|int32|int64|uint8|uint16|uint32|uint64)?\\b"
                },
                {
                    "name": "constant.numeric.decimal.pernix",
                    "match": "\\b[0-9][0-9_]*(i8|i16|i32|i64|u8|u16|u32|u64|isize|usize|int8|int16|int32|int64|uint8|uint16|uint32|uint64)?\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.comparison.pernix",
                    "match": "(==|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.assignment.pernix",
                    "match": "(\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|=)"
                },
                {
                    "name": "keyword.operator.arithmetic.pernix",
                    "match": "(\\+|-|\\*|/|%)"
                },
                {
                    "name": "keyword.operator.bitwise.pernix",
                    "match": "(&|\\||\\^|<<|>>|~)"
                },
                {
                    "name": "keyword.operator.access.pernix",
                    "match": "(\\.\\.|::|\\.)"
                },
                {
                    "name": "keyword.operator.reference.pernix",
                    "match": "&(mut\\s+)?"
                },
                {
                    "name": "keyword.operator.dereference.pernix",
                    "match": "\\*"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.brackets.square.pernix",
                    "match": "[\\[\\]]"
                },
                {
                    "name": "punctuation.brackets.round.pernix",
                    "match": "[()]"
                },
                {
                    "name": "punctuation.separator.comma.pernix",
                    "match": ","
                },
                {
                    "name": "punctuation.separator.colon.pernix",
                    "match": ":"
                },
                {
                    "name": "punctuation.separator.semicolon.pernix",
                    "match": ";"
                },
                {
                    "name": "punctuation.separator.arrow.pernix",
                    "match": "->"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.primitive.pernix",
                    "match": "\\b(bool|int8|int16|int32|int64|uint8|uint16|uint32|uint64|float32|float64|isize|usize)\\b"
                },
                {
                    "name": "entity.name.type.pernix",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.other.caps.pernix",
                    "match": "\\b[A-Z][A-Z0-9_]*\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "meta.function.declaration.pernix",
                    "begin": "\\b(def|express)\\s+([a-z_][a-zA-Z0-9_]*)\\b",
                    "end": "(?=[:(]|$)",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.other.pernix"
                        },
                        "2": {
                            "name": "entity.name.function.pernix"
                        }
                    },
                    "patterns": [
                        {
                            "name": "meta.generic.declaration.pernix",
                            "begin": "\\[",
                            "end": "\\]",
                            "patterns": [
                                {
                                    "include": "#lifetime"
                                },
                                {
                                    "include": "#types"
                                },
                                {
                                    "include": "#keywords"
                                },
                                {
                                    "include": "#operators"
                                },
                                {
                                    "include": "#punctuation"
                                },
                                {
                                    "include": "#identifiers"
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "meta.function.call.generic.pernix",
                    "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\[)",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.call.pernix"
                        }
                    }
                },
                {
                    "name": "entity.name.function.call.pernix",
                    "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.call.pernix"
                        }
                    }
                }
            ]
        },
        "generics": {
            "patterns": [
                {
                    "name": "meta.generic.pernix",
                    "begin": "(?<![a-zA-Z0-9_])([A-Z][a-zA-Z0-9_]*)\\s*\\[",
                    "end": "\\]",
                    "beginCaptures": {
                        "1": {
                            "name": "entity.name.type.pernix"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#lifetime"
                        },
                        {
                            "include": "#types"
                        },
                        {
                            "include": "#keywords"
                        },
                        {
                            "include": "#operators"
                        },
                        {
                            "include": "#punctuation"
                        },
                        {
                            "include": "#identifiers"
                        },
                        {
                            "include": "#generics"
                        }
                    ]
                }
            ]
        },
        "lifetime": {
            "patterns": [
                {
                    "name": "storage.modifier.lifetime.pernix",
                    "match": "'[a-z_][a-zA-Z0-9_]*\\b(?!')"
                }
            ]
        },
        "attributes": {
            "patterns": [
                {
                    "name": "meta.attribute.pernix",
                    "begin": "#\\[",
                    "end": "\\]",
                    "patterns": [
                        {
                            "include": "#strings"
                        },
                        {
                            "include": "#identifiers"
                        }
                    ]
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "variable.other.pernix",
                    "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    }
}
